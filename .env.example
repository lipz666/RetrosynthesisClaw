PYTHONPATH=src

# LLM provider mode: http (OpenAI-compatible API) or ollama (local model server)
MODEL_PROVIDER=http

# Base URL examples:
# - DeepSeek: https://api.deepseek.com
# - OpenAI: https://api.openai.com
# - Ollama: http://localhost:11434
MODEL_API_BASE_URL=https://api.deepseek.com

# HTTP API path for OpenAI-compatible providers
MODEL_API_PATH=/v1/chat/completions

# Model examples:
# - DeepSeek: deepseek-chat
# - OpenAI: gpt-4o
# - Ollama: llama3
MODEL_API_NAME=deepseek-chat

# Your API key; leave empty when using a local Ollama instance
MODEL_API_KEY=your_api_key_here

MODEL_TIMEOUT_SECONDS=300
